# Auto-detekcja plików tekstowych
* text=auto

# Wymuszenie LF (Linux style) dla kodu i configów
*.java text eol=lf
*.kt text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.properties text eol=lf
*.xml text eol=lf
*.md text eol=lf
*.txt text eol=lf

# Skrypty
*.sh text eol=lf
*.bat text eol=crlf

# Pliki binarne (bez konwersji)
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.zip binary
*.rar binary

# Logi (nieistotne dla diffów)
*.log text

# Gradle / Maven
gradlew text eol=lf
gradlew.bat text eol=crlf
*.gradle text eol=lf
pom.xml text eol=lf